{
  "version": 1,
  "profile": "node-npm",
  "baseBranch": "main",
  "packageManager": "npm",
  "executor": {
    "provider": "opencode",
    "opencode": {
      "bin": "opencode",
      "model": "opencode-go/deepseek-v4-pro"
    },
    "codex": {
      "bin": "codex",
      "model": "gpt-5.1-codex"
    }
  },
  "github": {
    "autoOpenPr": true,
    "prChecks": false
  },
  "checks": {
    "install": "npm ci",
    "branch": "npm run lint:branch --",
    "commits": "npx commitlint",
    "typecheck": "npm run test:types",
    "lint": "npm run lint",
    "format": "npm run format:check",
    "unit": "npm run test:unit",
    "openspec": "npm run openspec:cli --",
    "validateProposal": "npm run openspec:validate-proposal --"
  },
  "safety": {
    "enablePush": false,
    "enableArchive": false
  }
}

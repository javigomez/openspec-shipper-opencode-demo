{
  "name": "openspec-demo",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "openspec:cli": "env OPENSPEC_TELEMETRY=0 DO_NOT_TRACK=1 openspec",
    "openspec:validate-proposal": "node scripts/validate-openspec-proposal.mjs",
    "lint:branch": "node scripts/validate-branch-name.mjs",
    "lint:commits": "commitlint --from origin/main --to HEAD",
    "start": "node src/hello.js",
    "test:types": "node --check src/hello.js && node --check tests/hello.test.js",
    "lint": "node scripts/lint-no-tabs.mjs",
    "format:check": "node scripts/check-format.mjs",
    "test:unit": "node --test tests/hello.test.js",
    "check": "npm run test:types && npm run lint && npm run format:check && npm run test:unit"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@fission-ai/openspec": "^1.2.0",
    "openspec-shipper": "^0.1.23"
  }
}
